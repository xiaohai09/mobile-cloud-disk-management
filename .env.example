# ===========================================
# Docker Compose 环境变量示例
# ===========================================
# 使用方式：
#   cp .env.example .env
#   按实际部署环境修改强密码、域名和 SMTP 配置
#
# 注意：
# - docker-compose.yml 会自动读取项目根目录 .env
# - 不要提交真实 .env
# - 所有密码/密钥请使用强随机值

# ===========================================
# MySQL
# ===========================================
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_USER=caiyun_app
MYSQL_PASSWORD=replace_with_strong_app_password

# ===========================================
# Redis
# ===========================================
REDIS_PASSWORD=replace_with_strong_redis_password

# ===========================================
# 任务队列
# ===========================================
# list：默认 Redis List 可靠队列；streams：Redis Streams consumer group 队列。
TASK_QUEUE_BACKEND=list
TASK_QUEUE_STREAM_GROUP=caiyun-workers
TASK_QUEUE_STREAM_MAXLEN=100000

# ===========================================
# JWT / 会话
# ===========================================
JWT_SECRET=replace_with_32_chars_random_secret
JWT_ALGORITHM=HS256

# 逗号分隔；必须包含浏览器实际访问前端的完整 Origin（协议 + 域名/IP + 端口）
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ===========================================
# Worker 监控
# ===========================================
WORKER_MONITOR_TOKEN=replace_with_random_monitor_token
WORKER_MONITOR_HOST=0.0.0.0
WORKER_MONITOR_PORT=8081
WORKER_MONITOR_ALLOW_PLAINTEXT=true

# ===========================================
# 默认管理员账号（部署后自动创建）
# ===========================================
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace_with_strong_admin_password

# ===========================================
# Grafana
# ===========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_grafana_password

# ===========================================
# 邮箱服务（可选，用于密码找回验证码）
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=移动云盘
# 465 端口通常设为 true；587 端口通常设为 false 并由 SMTP STARTTLS 升级
SMTP_USE_TLS=false
