# ===========================================
# 前端 Vite 环境变量示例
# ===========================================
# 默认留空时：
# - HTTP API 使用同源相对路径 /api
# - WebSocket 使用同源相对路径 /ws
# Compose / Nginx 部署通常保持默认即可。

# 自定义 API 地址示例：http://localhost:8080
VITE_API_BASE_URL=

# 自定义 WebSocket 地址示例：ws://localhost:8080/ws
VITE_WS_URL=
