# ===========================================
# 移动云盘后端环境变量示例文件
# ===========================================
# 使用说明：
# 1. 复制本文件到 backend/.env（或按你的启动脚本指定路径）
# 2. 根据实际环境修改配置值
# 3. 不要提交真实 .env 到 Git（已在 .gitignore 中忽略）

# ===========================================
# 服务配置
# ===========================================
# API 服务监听端口
PORT=8080

# Worker 监控 HTTP 服务端口（/health、/status、/metrics）
WORKER_MONITOR_PORT=8081
WORKER_MONITOR_TOKEN=__GENERATE_RANDOM_MONITOR_TOKEN__
WORKER_RETRY_MAX_ATTEMPTS=3
WORKER_RETRY_DELAY=5s

# 兼容旧配置名（当前主程序不读取，可删除）
WORKER_PORT=8081

# 运行模式：debug / release / test
GIN_MODE=release

# 仅本地开发兜底使用；生产环境必须保持 false
ALLOW_INSECURE_DEFAULTS=false

# ===========================================
# MySQL 数据库配置
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=caiyun_app
DB_PASSWORD=__GENERATE_RANDOM_DB_PASSWORD__
MYSQL_ROOT_PASSWORD=__GENERATE_RANDOM_MYSQL_ROOT_PASSWORD__
MYSQL_USER=caiyun_app
MYSQL_PASSWORD=__GENERATE_RANDOM_DB_PASSWORD__
DB_NAME=caiyun

# 连接池配置（如代码未使用，可作为预留）
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=10m

# ===========================================
# Redis 配置
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=__GENERATE_RANDOM_REDIS_PASSWORD__
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_OPERATION_TIMEOUT=5s
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_TIMEOUT=4s
REDIS_IDLE_TIMEOUT=5m

# ===========================================
# JWT 配置
# ===========================================
# JWT_ALGORITHM 支持 HS256（默认）或 RS256。
# HS256 生产环境请替换为至少 32 位随机字符串。
JWT_ALGORITHM=HS256
JWT_SECRET=__GENERATE_32_BYTE_RANDOM_JWT_SECRET__
# RS256 可选配置：仅在 JWT_ALGORITHM=RS256 时启用，生产建议通过密钥管理系统注入。
# JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN RSA PUBLIC KEY-----\n...\n-----END RSA PUBLIC KEY-----"
JWT_EXPIRY=720
JWT_REFRESH_EXPIRY=2160

# ===========================================
# 邮箱服务配置（用于密码找回验证码）
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password_or_app_password
SMTP_FROM=no-reply@example.com
SMTP_FROM_NAME=移动云盘
# 465 端口通常设为 true；587 端口通常设为 false 并由 SMTP STARTTLS 升级
SMTP_USE_TLS=false

# ===========================================
# 任务系统配置
# ===========================================
TASK_CONCURRENCY=5
# 每日 08:00 执行一次，与 Worker 默认回退值保持一致
TASK_SCHEDULE=0 8 * * *
ENABLE_SIGN_IN=true
ENABLE_CLOUD_REWARD=true

# ===========================================
# 兑换中心配置
# ===========================================
EXCHANGE_CONCURRENCY=5
EXCHANGE_SCHEDULE_TIME_1=10:00
EXCHANGE_SCHEDULE_TIME_2=20:00
EXCHANGE_AUTO_UPDATE_PRODUCTS=true
EXCHANGE_UPDATE_TIME=6
EXCHANGE_ENABLED=true
EXCHANGE_ENABLE_PRIORITY=true
EXCHANGE_DEFAULT_TIMEOUT=60
EXCHANGE_MAX_GLOBAL_CONCURRENCY=20
EXCHANGE_AUTO_RETRY_FAILED=true
EXCHANGE_LOG_RETENTION_DAYS=30

# ===========================================
# 短信服务配置（按需启用）
# ===========================================
# 短信服务提供商：aliyun / tencent / unicom
SMS_PROVIDER=unicom
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_SIGN=移动云盘
SMS_RATE_LIMIT_DURATION=300
SMS_RATE_LIMIT_COUNT=1

# 彩云短信登录 / 滑块识别服务地址
# 抢兑滑块识别会调用：${CAIYUN_SMS_API_BASE_URL}/api/sms/solve
CAIYUN_SMS_API_BASE_URL=https://ydyp.apisky.cn

# 彩云短信登录 / 滑块识别服务 Token（优先读取 CAIYUN_SMS_API_TOKEN，未设置时回退 DEFAULT_API_TOKEN）
CAIYUN_SMS_API_TOKEN=
DEFAULT_API_TOKEN=

# 是否跳过短信接口 TLS 证书校验（仅调试时可设为 true，生产环境必须为 false）
CAIYUN_SMS_INSECURE_SKIP_VERIFY=false

# ===========================================
# 彩云认证（配置文件 auth 为空时回退读取）
# ===========================================
CAIYUN_AUTH=

# 任务中心需要跳过的任务 ID，多个 ID 用英文逗号分隔，例如：1,2,3
CAIYUN_TASKLIST_SKIP_IDS=

# ===========================================
# 限流配置
# ===========================================
# memory：单副本内存令牌桶；redis：多副本共享固定窗口限流。
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_WINDOW=1s

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs
# 兼容部分历史配置读取 LOG_PATH
LOG_PATH=./logs
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=7
LOG_MAX_AGE=30
LOG_COMPRESS=true
LOG_JSON_FORMAT=false

# ===========================================
# 监控与告警配置
# ===========================================
PROMETHEUS_PORT=9090
ENABLE_MONITORING=true
ALERT_NOTIFICATION=email
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_DISK_THRESHOLD=90

# Grafana Compose 示例服务配置
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_grafana_password

# ===========================================
# WebSocket 配置
# ===========================================
WS_HEARTBEAT_INTERVAL=30
WS_MAX_MESSAGE_SIZE=10240

# ===========================================
# 其他配置
# ===========================================
ENABLE_SWAGGER=false
ENABLE_CORS=false
# 逗号分隔允许的浏览器 Origin；Docker/反代部署请加入实际访问域名或 IP（含协议和端口）
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://yourdomain.com
REQUEST_TIMEOUT=30
MAX_UPLOAD_SIZE=50

# AI 云朵用户 ID 加密密钥（AES-128，长度必须为 16）。
# release 模式下必须配置；仅 ALLOW_INSECURE_DEFAULTS=true 的本地调试可回退协议默认值。
CAIYUN_AI_USERID_KEY=__16_BYTE_AES_KEY__

# 移动云盘 APP refreshToken 协议 AES Key；通常不需要修改，留空使用上游协议默认值。
CAIYUN_APP_REFRESH_AES_KEY=

# 认证用户快照缓存 TTL。改密/重置会主动失效缓存，TTL 仅影响主动失效失败时的兜底窗口。
AUTH_USER_CACHE_TTL=10s
